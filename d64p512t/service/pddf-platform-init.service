[Unit]
Description=PDDF module and device initialization service
Before=watchdog-control.service determine-reboot-cause.service pmon.service
DefaultDependencies=no

[Service]
Type=oneshot
ExecStart=/usr/local/bin/pddf_util.py install
ExecStop=/usr/local/bin/pddf_util.py clean
ExecStartPost=-/usr/local/bin/post_pddf_init.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
